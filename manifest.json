<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#f0ede6">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Buscaminas">
<meta name="mobile-web-app-capable" content="yes">
<meta name="description" content="Buscaminas para móvil — juego clásico con tablero personalizable">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-192.svg">
<title>Buscaminas</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap');

  :root {
    --bg: #f0ede6;
    --surface: #e8e4dc;
    --surface2: #dedad2;
    --border: #c8c4bc;
    --border2: #b8b4ac;
    --text: #1a1814;
    --muted: #7a7670;
    --accent: #c8f04a;
    --accent-dim: #8aaa2a;
    --danger: #ff4d4d;
    --danger-dim: #7a1f1f;
    --safe: #4dffaa;
    --safe-dim: #1a6644;
    --cell-hidden: #dedad0;
    --cell-revealed: #c8c4ba;
    --cell-border: #b0aca4;
    --n1:#60a8ff; --n2:#4dffaa; --n3:#ff6060; --n4:#bf80ff;
    --n5:#ffaa40; --n6:#40ffee; --n7:#ff80bf; --n8:#aaa;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html, body { height: 100%; overflow: hidden; background: var(--bg); color: var(--text); font-family: 'Space Mono', monospace; }

  #app {
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── HEADER ── */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px 10px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.04em;
    color: var(--accent);
  }
  .logo span { color: var(--text); }
  .header-stats {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .hstat {
    font-size: 11px;
    color: var(--muted);
    text-align: center;
    line-height: 1.3;
  }
  .hstat b { display: block; font-size: 15px; color: var(--text); font-weight: 700; }

  /* ── SCREENS ── */
  .screen { display: none; flex-direction: column; flex: 1; overflow: hidden; }
  .screen.active { display: flex; }

  /* ── CONFIG SCREEN ── */
  #config-screen {
    padding: 20px 18px;
    gap: 0;
    overflow-y: auto;
  }
  .section-title {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 14px;
    margin-top: 20px;
  }
  .section-title:first-child { margin-top: 0; }

  .presets-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 4px;
  }
  .preset-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 8px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .preset-card.selected {
    border-color: var(--accent);
    background: rgba(200,240,74,0.06);
  }
  .preset-card .preset-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--text);
    margin-bottom: 4px;
  }
  .preset-card .preset-sub {
    font-size: 10px;
    color: var(--muted);
  }

  .slider-group {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .slider-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .slider-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .slider-label .lname { font-size: 12px; color: var(--muted); }
  .slider-label .lval {
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
    font-family: 'Syne', sans-serif;
    min-width: 36px;
    text-align: right;
  }
  input[type=range] {
    -webkit-appearance: none;
    width: 100%;
    height: 4px;
    background: var(--border2);
    border-radius: 2px;
    outline: none;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
  }
  input[type=range]::-moz-range-thumb {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    cursor: pointer;
  }

  .mine-density-bar {
    height: 4px;
    border-radius: 2px;
    background: var(--border2);
    margin-top: -10px;
    overflow: hidden;
  }
  .mine-density-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--accent);
    transition: width 0.2s;
  }
  .density-label {
    font-size: 10px;
    color: var(--muted);
    text-align: right;
    margin-top: 4px;
  }

  .play-btn {
    margin-top: 24px;
    width: 100%;
    padding: 16px;
    background: var(--accent);
    color: #1a1814;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 16px;
    letter-spacing: -0.02em;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
  }
  .play-btn:active { opacity: 0.85; transform: scale(0.98); }

  /* ── GAME SCREEN ── */
  #game-screen {
    flex: 1;
    display: none;
    flex-direction: column;
    overflow: hidden;
  }
  #game-screen.active { display: flex; }

  .game-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .gstat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .gstat .gval {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--text);
    line-height: 1;
  }
  .gstat .glabel {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .gstat.danger .gval { color: var(--danger); }
  .gstat.safe .gval { color: var(--safe); }

  #reset-btn {
    width: 44px; height: 44px;
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 12px;
    font-size: 20px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.1s;
  }
  #reset-btn:active { background: var(--border); }

  .board-wrap {
    flex: 1;
    overflow: auto;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 10px;
    -webkit-overflow-scrolling: touch;
  }

  #board {
    display: inline-grid;
    gap: 2px;
    flex-shrink: 0;
  }

  .cell {
    width: 34px; height: 34px;
    border-radius: 6px;
    background: var(--cell-hidden);
    border: 1px solid var(--cell-border);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    user-select: none;
    transition: background 0.08s;
    position: relative;
  }
  .cell:active { background: var(--surface2); }
  .cell.revealed {
    background: var(--cell-revealed);
    border-color: #1a1a1a;
    cursor: default;
  }
  .cell.flagged { background: rgba(255,77,77,0.12); border-color: rgba(255,77,77,0.3); }
  .cell.mine-exploded { background: rgba(255,77,77,0.25); border-color: var(--danger); }
  .cell.mine-revealed { background: var(--cell-revealed); border-color: #222; }

  .cell .n1{color:var(--n1)} .cell .n2{color:var(--n2)} .cell .n3{color:var(--n3)}
  .cell .n4{color:var(--n4)} .cell .n5{color:var(--n5)} .cell .n6{color:var(--n6)}
  .cell .n7{color:var(--n7)} .cell .n8{color:var(--n8)}
  .num { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 14px; }

  /* ── OVERLAY ── */
  #overlay {
    display: none;
    position: absolute;
    inset: 0;
    background: rgba(240,237,230,0.92);
    z-index: 10;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 12px;
  }
  #overlay.show { display: flex; }
  .overlay-icon { font-size: 52px; line-height: 1; }
  .overlay-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.04em;
  }
  .overlay-sub { font-size: 13px; color: var(--muted); }
  .overlay-actions { display: flex; gap: 10px; margin-top: 8px; }
  .ov-btn {
    padding: 12px 22px;
    border-radius: 12px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s;
  }
  .ov-btn:active { opacity: 0.8; }
  .ov-btn.primary { background: var(--accent); color: #1a1814; }
  .ov-btn.secondary { background: var(--surface2); color: var(--text); border: 1px solid var(--border2); }

  /* ── BOTTOM NAV ── */
  .bottom-nav {
    display: flex;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }
  .nav-btn {
    flex: 1;
    padding: 12px 8px;
    background: transparent;
    border: none;
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    transition: color 0.15s;
  }
  .nav-btn .nav-icon { font-size: 18px; }
  .nav-btn.active { color: var(--accent); }

  /* flag toggle button */
  .flag-toggle {
    position: fixed;
    right: 16px;
    bottom: 72px;
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--surface2);
    border: 2px solid var(--border2);
    font-size: 22px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    z-index: 5;
    transition: background 0.15s, border-color 0.15s;
  }
  .flag-toggle.on { background: rgba(255,77,77,0.2); border-color: var(--danger); }
</style>
</head>
<body>
<div id="app">
  <header>
    <div class="logo">busca<span>minas</span></div>
    <div class="header-stats">
      <div class="hstat"><b id="h-played">0</b>jugadas</div>
      <div class="hstat"><b id="h-wins">0</b>victorias</div>
      <div class="hstat"><b id="h-best">--</b>mejor</div>
    </div>
  </header>

  <!-- CONFIG SCREEN -->
  <div class="screen active" id="config-screen">
    <div class="section-title">nivel</div>
    <div class="presets-grid">
      <div class="preset-card selected" data-preset="easy" onclick="selectPreset('easy',this)">
        <div class="preset-name">fácil</div>
        <div class="preset-sub">9×9 · 10 minas</div>
      </div>
      <div class="preset-card" data-preset="medium" onclick="selectPreset('medium',this)">
        <div class="preset-name">medio</div>
        <div class="preset-sub">16×16 · 40 minas</div>
      </div>
      <div class="preset-card" data-preset="hard" onclick="selectPreset('hard',this)">
        <div class="preset-name">difícil</div>
        <div class="preset-sub">16×30 · 99 minas</div>
      </div>
    </div>

    <div class="section-title" style="margin-top:22px">personalizado</div>
    <div class="slider-group">
      <div class="slider-row">
        <div class="slider-label"><span class="lname">filas</span><span class="lval" id="lv-rows">9</span></div>
        <input type="range" id="sl-rows" min="5" max="24" value="9" step="1">
      </div>
      <div class="slider-row">
        <div class="slider-label"><span class="lname">columnas</span><span class="lval" id="lv-cols">9</span></div>
        <input type="range" id="sl-cols" min="5" max="24" value="9" step="1">
      </div>
      <div class="slider-row">
        <div class="slider-label"><span class="lname">minas</span><span class="lval" id="lv-mines">10</span></div>
        <input type="range" id="sl-mines" min="1" max="71" value="10" step="1">
        <div class="mine-density-bar"><div class="mine-density-fill" id="density-fill" style="width:13%"></div></div>
        <div class="density-label" id="density-txt">densidad 13%</div>
      </div>
    </div>

    <button class="play-btn" onclick="goPlay()">▶ jugar</button>
  </div>

  <!-- GAME SCREEN -->
  <div class="screen" id="game-screen">
    <div class="game-bar">
      <div class="gstat" id="gs-mines">
        <div class="gval" id="gv-mines">0</div>
        <div class="glabel">minas</div>
      </div>
      <button id="reset-btn" onclick="resetGame()">↺</button>
      <div class="gstat" id="gs-flags">
        <div class="gval" id="gv-flags">0</div>
        <div class="glabel">banderas</div>
      </div>
      <div class="gstat">
        <div class="gval" id="gv-timer">0</div>
        <div class="glabel">segundos</div>
      </div>
    </div>

    <div class="board-wrap" id="board-wrap">
      <div id="board"></div>
    </div>

    <div id="overlay">
      <div class="overlay-icon" id="ov-icon"></div>
      <div class="overlay-title" id="ov-title"></div>
      <div class="overlay-sub" id="ov-sub"></div>
      <div class="overlay-actions">
        <button class="ov-btn primary" onclick="resetGame()">otra partida</button>
        <button class="ov-btn secondary" onclick="goConfig()">configurar</button>
      </div>
    </div>

    <button class="flag-toggle" id="flag-toggle" onclick="toggleFlagMode()">⚑</button>
  </div>

  <!-- BOTTOM NAV -->
  <div class="bottom-nav">
    <button class="nav-btn active" id="nav-config" onclick="goConfig()">
      <span class="nav-icon">⚙</span>config
    </button>
    <button class="nav-btn" id="nav-game" onclick="goPlay()">
      <span class="nav-icon">◼</span>jugar
    </button>
  </div>
</div>

<script>
// ── STATE ──
let R, C, MINES, board, revealed, flagged, gameOver, firstClick, timerInt, secs, flags, flagMode;
let stats = JSON.parse(localStorage.getItem('bm_stats') || '{"played":0,"wins":0,"best":null}');

// ── SLIDERS ──
const slR = document.getElementById('sl-rows');
const slC = document.getElementById('sl-cols');
const slM = document.getElementById('sl-mines');
const lvR = document.getElementById('lv-rows');
const lvC = document.getElementById('lv-cols');
const lvM = document.getElementById('lv-mines');
const dFill = document.getElementById('density-fill');
const dTxt = document.getElementById('density-txt');

function updateDensity() {
  const r = +slR.value, c = +slC.value, m = +slM.value;
  const max = Math.max(1, Math.floor(r * c * 0.85));
  slM.max = max;
  if (m > max) { slM.value = max; lvM.textContent = max; }
  else lvM.textContent = slM.value;
  const pct = Math.round(slM.value / (r*c) * 100);
  dFill.style.width = pct + '%';
  dFill.style.background = pct > 50 ? '#ff6060' : pct > 30 ? '#ffaa40' : '#c8f04a';
  dTxt.textContent = 'densidad ' + pct + '%';
  // deselect presets
  document.querySelectorAll('.preset-card').forEach(el => el.classList.remove('selected'));
}

slR.oninput = () => { lvR.textContent = slR.value; updateDensity(); };
slC.oninput = () => { lvC.textContent = slC.value; updateDensity(); };
slM.oninput = () => { updateDensity(); };

function selectPreset(name, el) {
  document.querySelectorAll('.preset-card').forEach(x => x.classList.remove('selected'));
  el.classList.add('selected');
  const p = {easy:[9,9,10], medium:[16,16,40], hard:[16,24,99]}[name];
  slR.value = p[0]; lvR.textContent = p[0];
  slC.value = p[1]; lvC.textContent = p[1];
  slM.max = Math.floor(p[0]*p[1]*0.85);
  slM.value = p[2]; updateDensity();
}

// ── NAVIGATION ──
function goConfig() {
  document.getElementById('config-screen').classList.add('active');
  document.getElementById('game-screen').classList.remove('active');
  document.getElementById('nav-config').classList.add('active');
  document.getElementById('nav-game').classList.remove('active');
}
function goPlay() {
  document.getElementById('config-screen').classList.remove('active');
  document.getElementById('game-screen').classList.add('active');
  document.getElementById('nav-config').classList.remove('active');
  document.getElementById('nav-game').classList.add('active');
  startGame();
}

// ── GAME LOGIC ──
function startGame() {
  R = +slR.value; C = +slC.value; MINES = +slM.value;
  board = Array.from({length:R}, () => Array(C).fill(0));
  revealed = Array.from({length:R}, () => Array(C).fill(false));
  flagged = Array.from({length:R}, () => Array(C).fill(false));
  gameOver = false; firstClick = true; secs = 0; flags = 0; flagMode = false;
  clearInterval(timerInt);
  document.getElementById('gv-mines').textContent = MINES;
  document.getElementById('gv-flags').textContent = 0;
  document.getElementById('gv-timer').textContent = 0;
  document.getElementById('overlay').classList.remove('show');
  document.getElementById('flag-toggle').classList.remove('on');
  renderBoard();
}

function resetGame() { startGame(); }

function placeMines(sr, sc) {
  let placed = 0;
  while (placed < MINES) {
    const r = Math.floor(Math.random()*R), c = Math.floor(Math.random()*C);
    if (board[r][c] !== -1 && !(Math.abs(r-sr)<=1 && Math.abs(c-sc)<=1)) {
      board[r][c] = -1; placed++;
    }
  }
  for (let r=0;r<R;r++) for (let c=0;c<C;c++) if (board[r][c]!==-1) {
    let n=0;
    for (let dr=-1;dr<=1;dr++) for (let dc=-1;dc<=1;dc++) {
      const nr=r+dr,nc=c+dc;
      if (nr>=0&&nr<R&&nc>=0&&nc<C&&board[nr][nc]===-1) n++;
    }
    board[r][c]=n;
  }
}

function renderBoard() {
  const b = document.getElementById('board');
  b.style.gridTemplateColumns = `repeat(${C}, 34px)`;
  b.innerHTML = '';
  for (let r=0;r<R;r++) for (let c=0;c<C;c++) {
    const cell = document.createElement('div');
    cell.className = 'cell';
    cell.dataset.r = r; cell.dataset.c = c;
    // Touch: short tap = reveal/flag depending on mode; long press toggles flag
    let pressTimer = null;
    cell.addEventListener('touchstart', e => {
      pressTimer = setTimeout(() => {
        pressTimer = null;
        handleFlag(r, c);
      }, 450);
    }, {passive:true});
    cell.addEventListener('touchend', e => {
      if (pressTimer !== null) {
        clearTimeout(pressTimer);
        pressTimer = null;
        if (flagMode) handleFlag(r,c);
        else handleReveal(r,c);
      }
    });
    cell.addEventListener('touchmove', () => { if(pressTimer){clearTimeout(pressTimer);pressTimer=null;} }, {passive:true});
    // Mouse fallback
    cell.addEventListener('click', () => { if(flagMode) handleFlag(r,c); else handleReveal(r,c); });
    cell.addEventListener('contextmenu', e => { e.preventDefault(); handleFlag(r,c); });
    b.appendChild(cell);
  }
}

function cellEl(r,c) { return document.getElementById('board').children[r*C+c]; }

function handleReveal(r,c) {
  if (gameOver || flagged[r][c] || revealed[r][c]) return;
  if (firstClick) {
    firstClick = false;
    placeMines(r,c);
    timerInt = setInterval(() => { secs++; document.getElementById('gv-timer').textContent = secs; }, 1000);
  }
  if (board[r][c]===-1) { explode(r,c); return; }
  reveal(r,c);
  checkWin();
}

function handleFlag(r,c) {
  if (gameOver || revealed[r][c]) return;
  flagged[r][c] = !flagged[r][c];
  flags += flagged[r][c] ? 1 : -1;
  document.getElementById('gv-flags').textContent = flags;
  const el = cellEl(r,c);
  if (flagged[r][c]) {
    el.classList.add('flagged');
    el.innerHTML = '<span style="font-size:16px">⚑</span>';
  } else {
    el.classList.remove('flagged');
    el.innerHTML = '';
  }
}

function reveal(r,c) {
  if (r<0||r>=R||c<0||c>=C||revealed[r][c]||flagged[r][c]) return;
  revealed[r][c]=true;
  const el = cellEl(r,c);
  el.classList.add('revealed');
  if (board[r][c]>0) {
    el.innerHTML = `<span class="num n${board[r][c]}">${board[r][c]}</span>`;
  }
  if (board[r][c]===0) {
    for (let dr=-1;dr<=1;dr++) for (let dc=-1;dc<=1;dc++) reveal(r+dr,c+dc);
  }
}

function explode(er,ec) {
  gameOver = true; clearInterval(timerInt);
  for (let r=0;r<R;r++) for (let c=0;c<C;c++) {
    if (board[r][c]===-1) {
      const el = cellEl(r,c);
      if (r===er&&c===ec) { el.classList.add('mine-exploded'); el.innerHTML='<span style="font-size:18px">💥</span>'; }
      else if (!flagged[r][c]) { el.classList.add('mine-revealed'); el.innerHTML='<span style="font-size:15px;opacity:.7">●</span>'; }
    }
  }
  stats.played++;
  localStorage.setItem('bm_stats', JSON.stringify(stats));
  updateStatsUI();
  showOverlay(false);
}

function checkWin() {
  let unrevealed = 0;
  for (let r=0;r<R;r++) for (let c=0;c<C;c++) if (!revealed[r][c]) unrevealed++;
  if (unrevealed===MINES) {
    gameOver = true; clearInterval(timerInt);
    stats.played++;
    stats.wins++;
    if (stats.best===null || secs < stats.best) stats.best = secs;
    localStorage.setItem('bm_stats', JSON.stringify(stats));
    updateStatsUI();
    showOverlay(true);
  }
}

function showOverlay(win) {
  const ov = document.getElementById('overlay');
  document.getElementById('ov-icon').textContent = win ? '🏆' : '💣';
  document.getElementById('ov-title').textContent = win ? '¡Victoria!' : 'Fin de partida';
  document.getElementById('ov-title').style.color = win ? '#c8f04a' : '#ff4d4d';
  document.getElementById('ov-sub').textContent = win
    ? `Completado en ${secs}s · ${R}×${C} · ${MINES} minas`
    : `Tablero: ${R}×${C} · ${MINES} minas`;
  ov.classList.add('show');
}

function toggleFlagMode() {
  flagMode = !flagMode;
  document.getElementById('flag-toggle').classList.toggle('on', flagMode);
}

function updateStatsUI() {
  document.getElementById('h-played').textContent = stats.played;
  document.getElementById('h-wins').textContent = stats.wins;
  document.getElementById('h-best').textContent = stats.best !== null ? stats.best+'s' : '--';
}

updateStatsUI();
updateDensity();

// ── SERVICE WORKER ──
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(() => {});
}
</script>
</body>
</html>
